# ── FarmEase FastAPI Backend ──────────────────────────────────
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# AI Chat (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace (Text-to-Speech)
HUGGINGFACE_API_KEY=your_huggingface_key_here

# API Authentication — set a strong random key
# Mobile app must send this as X-API-Key header
FARMEASE_API_KEY=your_random_api_key_here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Rate limiting
RATE_LIMIT_PER_MIN=10

# Set to true to run without API keys (mock responses)
MOCK_MODE=false
